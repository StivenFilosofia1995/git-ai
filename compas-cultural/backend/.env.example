# ============================================
# BACKEND (.env)
# ============================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Anthropic (Chat IA)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Chat engine selector: ollama | groq | gemini | anthropic | auto
CHAT_ENGINE=ollama

# Ollama LLM (gratis, sin API key)
# Usa localhost solo si Ollama corre en el mismo servicio/contenedor que FastAPI.
# En Railway, si Ollama vive en otro servicio, apunta esta variable a esa URL interna/externa.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:1.5b

# Embeddings
OPENAI_API_KEY=sk-...  # Para text-embedding-3-small

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...
GOOGLE_GEOCODING_API_KEY=AIza...

# Apify (Instagram scraping)
APIFY_API_TOKEN=apify_api_...

# Scraping
SCRAPING_INTERVAL_HOURS=6
SCRAPING_INSTAGRAM_ENABLED=true
SCRAPING_GOOGLE_ENABLED=true
SCRAPING_WEB_ENABLED=true

# App
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Scraper protection (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SCRAPER_API_KEY=change-me-to-a-random-secret

# Rate limiting
RATE_LIMIT_PER_MINUTE=60